# Whyline — Company Memory Engine
# cp .env.example .env && npm run setup && npm run dev

# ===== 1. LLM (required for AI) =====
LLM_API_KEY=your_groq_api_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL_NAME=qwen/qwen3-32b

# ===== 2. API auth (optional — auto-generated to data/.api_key on first boot) =====
WHYLINE_API_KEY=

# ===== 3. Slack integration (optional — both required for events endpoint) =====
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ===== 4. Webhook secrets (required when that integration is enabled) =====
ATLASSIAN_WEBHOOK_SECRET=
EMAIL_WEBHOOK_SECRET=
GITHUB_WEBHOOK_SECRET=
TEAMS_WEBHOOK_SECRET=
LINEAR_WEBHOOK_SECRET=
SALESFORCE_WEBHOOK_SECRET=

# ===== 5. Server (localhost by default — do not expose secrets on LAN) =====
WHYLINE_HOST=127.0.0.1
WHYLINE_PORT=8793
WHYLINE_AUTH_MODE=solo
# MCP: optional explicit workspace (defaults to service-token / solo default workspace)
MCP_WORKSPACE_ID=
WHYLINE_DB_PATH=
FLASK_DEBUG=False
RETRIEVAL_TOP_K=8
NEAR_DUP_SCORE_THRESHOLD=4.0
WEBHOOK_DECISION_MARKERS=[decision],#decision,decision:,adr:,whyline:

# Optional — leave empty to disable in-app donations (see README Support section)
SOL_DONATION_ADDRESS=